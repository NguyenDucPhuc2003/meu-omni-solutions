# MeuOmni Modular Solution - Environment Configuration Example
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# =============================================================================
# DATABASE CONFIGURATION - SalesChannel Module
# =============================================================================
Modules__SalesChannel__Database__ConnectionString=Host=localhost;Port=5432;Database=qlbh_sales_channel;Username=postgres;Password=change-me

# =============================================================================
# DATABASE CONFIGURATION - SimpleCommerce Module
# =============================================================================
Modules__SimpleCommerce__Database__ConnectionString=Host=localhost;Port=5432;Database=qlbh_simple_commerce;Username=postgres;Password=change-me

# =============================================================================
# JWT AUTHENTICATION (for future implementation)
# =============================================================================
Jwt__Issuer=meu-omni
Jwt__Audience=meu-omni-clients
Jwt__SecurityKey=replace-with-a-strong-secret-key-at-least-32-chars
Jwt__ExpirationMinutes=480

# =============================================================================
# ASPNETCORE ENVIRONMENT
# =============================================================================
# ASPNETCORE_ENVIRONMENT=Development

# =============================================================================
# NOTES
# =============================================================================
# 1. Each module has its own database - this is intentional (database-per-module pattern)
# 2. You can use the same PostgreSQL server but different database names
# 3. For local development, you can use the same credentials for all modules
# 4. For production, consider using different credentials per module for better security
# 5. Connection string format matches appsettings.json structure with __ (double underscore) as separator

